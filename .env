BOT_TOKEN=SIZNING_BOT_TOKENINGIZNI_SHU_YERGA_QOYING
DEFAULT_REMINDER_TIME=09:00

# PostgreSQL sozlamalari (docker-compose shulardan foydalanadi)
POSTGRES_USER=macbookair
POSTGRES_PASSWORD=1111
POSTGRES_DB=todo_bot

# Lokal (docker'siz) ishga tushirish uchun DATABASE_URL
# Docker orqali ishga tushirganda buni e'tiborga olmang - compose o'zi to'g'ri qiymatni beradi
DATABASE_URL=postgresql://macbookair:1111@localhost:5432/todo_bot
